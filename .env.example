# ── Server only (never exposed to browser) ──────────────────
# Direct URL to the PostgREST process on this machine
POSTGREST_URL=http://localhost:3001

# HTTP Basic Auth for the whole dashboard (see middleware.ts).
# Leave both unset to disable auth (e.g. local dev).
DASHBOARD_USERNAME=Sbdaram
DASHBOARD_PASSWORD=abc123

# Google Places — server only (used by /api/google-places routes)
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# ── Client (browser) ────────────────────────────────────────
# Path to the Next.js proxy that forwards to PostgREST
# Use a relative path on production (recommended):
NEXT_PUBLIC_POSTGREST_URL=/api/db

# Optional — not used by the app today, safe to omit:
# NEXT_PUBLIC_APP_URL=https://srt.sbd-one.com
# NEXT_PUBLIC_API_URL=/api/db

# ── Not used by this Next.js app ────────────────────────────
# Postgres is accessed by PostgREST via postgrest.conf, not here.
# DATABASE_URL=postgresql://aram_user:aram123@localhost:5432/aram_roadtrip
